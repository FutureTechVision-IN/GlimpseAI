# =============================================================================
# GlimpseAI — Environment Variables
# Copy this file to .env and fill in your actual keys
# =============================================================================

# ── Server ───────────────────────────────────────────────────
PORT=3001
WEB_PORT=5173
NODE_ENV=development

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://bipbabu:@localhost:5432/glimpseai
POSTGRES_DB=glimpseai
POSTGRES_USER=bipbabu
POSTGRES_PASSWORD=

# ── Admin ────────────────────────────────────────────────────
ADMIN_NAME=Glimpse Admin
ADMIN_EMAIL=admin@glimpse.ai
# Optional second admin (shares ADMIN_PASSWORD). Required in production if you want both; in dev defaults if unset:
ADMIN_NAME_2=Future Tech Vision
ADMIN_EMAIL_2=futuretechvision.global@gmail.com
# Required in production (with ADMIN_EMAIL). Both bootstrap admins use this password. Dev: set ALLOW_INSECURE_DEV_ADMIN=true for a weak default instead.
ADMIN_PASSWORD=
# Production only: set to true for one boot to re-hash ADMIN_PASSWORD when the admin user already exists (then remove or set false).
# ADMIN_SYNC_PASSWORD_ON_BOOT=

# ── AI Provider Keys ────────────────────────────────────────
# Primary tier (premium, high-quality vision/LLM models):
# PROVIDER_KEYS_MOONSHOTAI_KIMI_K2_5=sk-or-v1-xxx,sk-or-v1-yyy
# PROVIDER_KEYS_BYTEDANCE_SEEDANCE_2_0=sk-or-v1-xxx
# PROVIDER_KEYS_ALIBABA_WAN_2_7=sk-or-v1-xxx
# PROVIDER_KEYS_OPENROUTER_ELEPHANT_ALPHA=sk-or-v1-xxx

# Standard tier (free, text/vision models):
# PROVIDER_KEYS_STEPFUN_STEP_3_5_FLASH_FREE=sk-or-v1-xxx
# Multiple keys (comma-separated) spread load across the same model pool:
# PROVIDER_KEYS_TENCENT_HY3_PREVIEW_FREE=sk-or-v1-key-a,sk-or-v1-key-b
# PROVIDER_KEYS_NVIDIA_NEMOTRON_3_SUPER_120B_A12B_FREE=sk-or-v1-xxx
# PROVIDER_KEYS_NVIDIA_NEMOTRON_3_NANO_30B_A3B_FREE=sk-or-v1-xxx
# PROVIDER_KEYS_ZAI_GLM_4_5_AIR_FREE=sk-or-v1-xxx
# PROVIDER_KEYS_OPENAI_GPT_OSS_120B_FREE=sk-or-v1-xxx

# Gemini (last-resort fallback, premium only):
# GEMINI_API_KEYS=AIzaXXXXX,AIzaYYYYY

# NVIDIA direct API (all NVIDIA-hosted models):
# NVIDIA_API_KEY=nvapi-xxx

# ── OpenRouter ───────────────────────────────────────────────
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── Restoration Service ──────────────────────────────────────
RESTORATION_SERVICE_URL=http://localhost:7860
RESTORATION_PORT=7860

# ── Payments (Razorpay) ─────────────────────────────────────
# RAZORPAY_KEY_ID=rzp_test_xxx
# RAZORPAY_KEY_SECRET=xxx
# Development only: allow verify without real keys (never in production)
# PAYMENT_VERIFY_DISABLED=true

# ── Media retention (stateless blobs) ─────────────────────────
# Hours before base64 columns are cleared from completed jobs (metadata kept)
# MEDIA_RETENTION_HOURS=48
# MEDIA_RETENTION_INTERVAL_MS=3600000

# ── Batch limits (optional overrides) ───────────────────────
# BATCH_MAX_BASIC=5
# BATCH_MAX_PREMIUM=10

# ── Security ─────────────────────────────────────────────────
# SESSION_SECRET must be 32+ random characters in production (JWT signing).
# SESSION_SECRET=
# KEY_ENCRYPTION_SECRET=your-encryption-secret-here

# ── Boot hooks (optional) ───────────────────────────────────
# VALIDATE_ADMIN_ON_BOOT=true
# ENABLE_ADMIN_SELF_TEST=true
# ALLOW_INSECURE_DEV_ADMIN=true
