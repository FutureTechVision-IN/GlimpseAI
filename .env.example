# GlimpseAI Environment Configuration
# Copy this file to .env and fill in your actual values.

# ============================================================================
# Database Configuration
# ============================================================================
DATABASE_URL=postgresql://postgres:password@localhost:5432/glimpseai
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=glimpseai

# ============================================================================
# API Server Configuration
# ============================================================================
NODE_ENV=development
PORT=3001
API_PORT=3001
SESSION_SECRET=your-session-secret-here
CORS_ORIGIN=http://localhost:5173
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# ============================================================================
# Admin Account (created on first run)
# ============================================================================
ADMIN_NAME=Glimpse Admin
ADMIN_EMAIL=admin@glimpse.ai
ADMIN_PASSWORD=change-me-immediately

# ============================================================================
# AI Provider Keys (OpenRouter)
# ============================================================================
# Get keys from https://openrouter.ai/keys
PROVIDER_KEYS_STEPFUN_STEP_3_5_FLASH_FREE=sk-or-v1-your-key-here
PROVIDER_KEYS_NVIDIA_NEMOTRON_3_SUPER_120B_A12B_FREE=sk-or-v1-your-key-here
PROVIDER_KEYS_NVIDIA_NEMOTRON_3_NANO_30B_A3B_FREE=sk-or-v1-your-key-here
PROVIDER_KEYS_ZAI_GLM_4_5_AIR_FREE=sk-or-v1-your-key-here

# OpenRouter API base URL
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ============================================================================
# Google Gemini API Keys
# ============================================================================
# Get keys from https://aistudio.google.com/apikey
GEMINI_API_KEYS=your-gemini-key-here

# ============================================================================
# Razorpay (Payments)
# ============================================================================
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# ============================================================================
# Frontend
# ============================================================================
VITE_API_URL=http://localhost:3001

# ============================================================================
# Media Storage (Google Drive)
# ============================================================================
# Shared Drive folder for GlimpseAI media:
# https://drive.google.com/drive/folders/17-NtAES7W6ua0FS7mqYX3-thbRkQkLQG
GOOGLE_DRIVE_FOLDER_ID=17-NtAES7W6ua0FS7mqYX3-thbRkQkLQG
# Use either GOOGLE_APPLICATION_CREDENTIALS or service-account email/key.
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
# Set false if the folder's sharing policy already handles access.
GOOGLE_DRIVE_MAKE_PUBLIC=true
