#!/usr/bin/env bash
# =============================================================================
# GlimpseAI Pre-Commit Secret Scanner
# Blocks commits that contain .env files or known secret patterns.
# Installed automatically via: git config core.hooksPath .githooks
# =============================================================================

set -e

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m' # No Color

BLOCKED=0

# -----------------------------------------------------------------------------
# 1. Block .env files from being staged at all
# -----------------------------------------------------------------------------
ENV_FILES=$(git diff --cached --name-only | grep -E '(^|/)\.env(\.|$)' || true)
if [ -n "$ENV_FILES" ]; then
  echo -e "${RED}[SECURITY BLOCK] .env file staged for commit:${NC}"
  echo "$ENV_FILES" | sed 's/^/  /'
  echo -e "${YELLOW}  Remove it: git reset HEAD -- <file>${NC}"
  BLOCKED=1
fi

# -----------------------------------------------------------------------------
# 2. Scan staged file CONTENTS for known secret patterns
# -----------------------------------------------------------------------------
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

# Patterns that indicate real secrets (not placeholders or comments)
SECRET_PATTERNS=(
  # OpenRouter API keys
  'sk-or-v[0-9]-[0-9a-f]{60,}'
  # Google / Gemini API keys
  'AIzaSy[0-9A-Za-z_-]{33}'
  # Generic "AQ.Ab8" pattern (Google service account tokens)
  'AQ\.Ab8[A-Za-z0-9_-]{10,}'
  # Razorpay live keys (not test placeholders)
  'rzp_live_[A-Za-z0-9]{14,}'
  # Generic high-entropy bearer / JWT-like tokens > 40 chars (sk-, ghp-, etc.)
  'ghp_[A-Za-z0-9]{36}'
  'github_pat_[A-Za-z0-9_]{82}'
  # AWS
  'AKIA[0-9A-Z]{16}'
  # Generic OpenAI
  'sk-[A-Za-z0-9]{48}'
)

for file in $STAGED_FILES; do
  # Skip binary files
  if git show :"$file" 2>/dev/null | file - | grep -q "binary"; then
    continue
  fi

  for pattern in "${SECRET_PATTERNS[@]}"; do
    MATCH=$(git show :"$file" 2>/dev/null | grep -oE "$pattern" | head -1 || true)
    if [ -n "$MATCH" ]; then
      # Show only first/last 4 chars of the secret
      REDACTED="${MATCH:0:8}...${MATCH: -4}"
      echo -e "${RED}[SECURITY BLOCK] Secret detected in '${file}':${NC}"
      echo -e "  Pattern: ${YELLOW}${pattern}${NC}"
      echo -e "  Value:   ${YELLOW}${REDACTED}${NC} (redacted)"
      BLOCKED=1
    fi
  done
done

# -----------------------------------------------------------------------------
# 3. Hard block: never allow commit to gh-pages with source code directories
# -----------------------------------------------------------------------------
CURRENT_BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null || echo "detached")
if [ "$CURRENT_BRANCH" = "gh-pages" ]; then
  SOURCE_FILES=$(git diff --cached --name-only | grep -E '^(artifacts|lib|scripts|node_modules)/' | head -5 || true)
  if [ -n "$SOURCE_FILES" ]; then
    echo -e "${RED}[SECURITY BLOCK] Source code staged on gh-pages branch:${NC}"
    echo "$SOURCE_FILES" | sed 's/^/  /'
    echo -e "${YELLOW}  gh-pages should only contain built assets (HTML/CSS/JS).${NC}"
    BLOCKED=1
  fi
fi

# -----------------------------------------------------------------------------
# Result
# -----------------------------------------------------------------------------
if [ "$BLOCKED" -eq 1 ]; then
  echo ""
  echo -e "${RED}╔══════════════════════════════════════════════════════════╗${NC}"
  echo -e "${RED}║  COMMIT BLOCKED: Secrets or unsafe files detected        ║${NC}"
  echo -e "${RED}║  Rotate any exposed keys IMMEDIATELY if already pushed.  ║${NC}"
  echo -e "${RED}╚══════════════════════════════════════════════════════════╝${NC}"
  echo ""
  exit 1
fi

echo -e "${GREEN}[pre-commit] Secret scan passed.${NC}"
exit 0
